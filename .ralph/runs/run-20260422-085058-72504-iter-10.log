+    "baseUrl": "http://127.0.0.1:11434/v1"
+  },
+  "env": {
+    "OPENAI_API_KEY": "ollama"
+  },
+  "localRouting": {
+    "enabled": true,
+    "englishModel": "gemma3",
+    "traditionalChineseModel": "qwen3:8b",
+    "bilingualModel": "qwen3:8b",
+    "fallbackModel": "llama3.2"
+  },
+  "privacy": {
+    "localOnly": true
+  }
+}
+```

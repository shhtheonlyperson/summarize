+      : typeof value.localOnly === "undefined"
+        ? undefined
+        : (() => {
+            throw new Error(`Invalid config file ${path}: "privacy.localOnly" must be a boolean.`);
+          })();
+
+  return typeof localOnly === "boolean" ? { localOnly } : undefined;

+        ["llama-cpp", "127.0.0.1:8080"],
+        ["ollama", "127.0.0.1:11434"],
+      ]);
+      expect(fetchImpl).toHaveBeenCalledTimes(2);
+    } finally {
+      abortController.abort();
+      await serverPromise;
+    }
+  });
+});


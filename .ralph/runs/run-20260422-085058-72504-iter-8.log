+    return host || null;
+  } catch {
+    return null;
+  }
+}
+
+function configuredOpenAiBaseUrl({
+  env,
+  config,
+}: {
+  env: Record<string, string | undefined>;
+  config: SummarizeConfig | null;
+}): string | null {

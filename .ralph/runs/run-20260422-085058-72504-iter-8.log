     const ffmpegPath = resolveToolPath("ffmpeg", env, "FFMPEG_PATH");
diff --git a/tests/daemon.local-runtime-status.test.ts b/tests/daemon.local-runtime-status.test.ts
new file mode 100644
index 0000000000000000000000000000000000000000..6054e5686e8e99404689911cbd605b196817928d

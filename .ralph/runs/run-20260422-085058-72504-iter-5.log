+  ctx: RefreshContext & { setExitCode?: (code: number) => void },
+): Promise<boolean> {
+  return handleLocalRuntimeProbeRequest({
+    normalizedArgv: ctx.normalizedArgv,
+    envForRun: ctx.envForRun,
+    fetchImpl: ctx.fetchImpl,
+    stdout: ctx.stdout,
+    setExitCode: ctx.setExitCode,
+  });
+}

+    requiredIndexes: ["idx_research_memory_settings_updated_at"],
+  },
+  {
+    name: "runs",
+    table: "research_runs",
+    requiredColumns: [
+      "id",
+      "kind",
+      "mode",
+      "status",
+      "created_at",
+      "started_at",
+      "completed_at",

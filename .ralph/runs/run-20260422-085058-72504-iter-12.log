+export const RESEARCH_MEMORY_SCHEMA_VERSION = 1;
+export const RESEARCH_MEMORY_INITIAL_MIGRATION = "001_initial.sql";
+
+export const DEFAULT_RESEARCH_MEMORY_DB_PATH = "~/.summarize/research-memory.sqlite";

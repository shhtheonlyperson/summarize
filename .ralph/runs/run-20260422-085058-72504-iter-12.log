+      "requested_format",
+      "summary_artifact_id",
+      "metrics_json",
+      "config_fingerprint",
+      "privacy_mode_json",
+    ],
+    requiredIndexes: [
+      "idx_research_runs_status_created_at",
+      "idx_research_runs_kind_created_at",
+      "idx_research_runs_config_fingerprint",
+    ],
+  },
+  {
+    name: "sources",

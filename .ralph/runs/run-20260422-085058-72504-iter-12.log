+      "url_hash",
+      "title",
+      "site_name",
+      "content_type",
+      "language_hint",
+      "content_hash",
+      "extracted_artifact_id",
+      "fetch_metadata_json",
+      "created_at",
+    ],
+    requiredIndexes: [
+      "idx_research_sources_run_id",

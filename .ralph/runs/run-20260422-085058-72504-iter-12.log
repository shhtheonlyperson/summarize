+  },
+] as const satisfies readonly ResearchMemorySchemaEntity[];
+
+export const RESEARCH_MEMORY_REQUIRED_TABLES = RESEARCH_MEMORY_SCHEMA_ENTITIES.map(
+  (entity) => entity.table,

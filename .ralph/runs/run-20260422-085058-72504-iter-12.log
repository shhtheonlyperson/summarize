+      "storage_kind",
+      "relative_path",
+      "inline_text",
+      "inline_json",
+      "mime_type",
+      "byte_size",
+      "sha256",
+      "privacy_class",
+      "retention",
+      "metadata_json",
+      "created_at",
+    ],
+    requiredIndexes: [
+      "idx_research_artifacts_run_id",

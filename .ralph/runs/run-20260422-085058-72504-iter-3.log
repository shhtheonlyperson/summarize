+  kind: LocalRuntimeKind;
+  label: string;
+  protocol: LocalRuntimeProtocol;
+  baseUrl: string;
+  baseUrlSource: LocalRuntimeBaseUrlSource;
+  modelsPath: string;
+  openAiCompatibleBaseUrl: string;
+};

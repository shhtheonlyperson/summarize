+  kind: "openai-compatible";
+  protocol: "openai-compatible";
+  modelsPath: "/models";
+};
+
+export type LlamaCppLocalRuntimeDescriptor = LocalRuntimeDescriptorBase & {
+  kind: "llama-cpp";
+  protocol: "openai-compatible";
+  modelsPath: "/models";
+};
+
+export type OllamaLocalRuntimeDescriptor = LocalRuntimeDescriptorBase & {
+  kind: "ollama";
+  protocol: "ollama";
+  modelsPath: "/api/tags";
+};
+

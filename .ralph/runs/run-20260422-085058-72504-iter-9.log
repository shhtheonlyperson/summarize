+        kind: string;
+        tag?: string;
+        label?: string;
+      };
+    }>;
+  };
+  probes: LocalRuntimeStatusProbe[];
+  warnings: string[];
+};
+
+export type LocalRuntimeStatus =
+  | LocalRuntimeStatusPayload
+  | {
+      ok: false;
+      error: string;
+    };
+
 export type UiState = {

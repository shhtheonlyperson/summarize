+  modelHints: {
+    configuredModel: {
+      input: string;
+      source: "env" | "config" | "default";
+    };
+    localRoutingEnabled: boolean;
+    selected: {
+      bucket: "english" | "traditionalChinese" | "bilingual" | "fallback";
+      modelInput: string;
+      language: {
+        kind: string;
+        tag?: string;
+        label?: string;
+      };
+    } | null;
+    routes: Array<{

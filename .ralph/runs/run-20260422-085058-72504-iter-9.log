+      modelInput: string;
+      language: {
+        kind: string;
+        tag?: string;
+        label?: string;
+      };
+    }>;
+  };
+  probes: LocalRuntimeStatusProbe[];
+  warnings: string[];
+};
+
+export type LocalRuntimeStatus =
+  | LocalRuntimeStatusPayload
+  | {
+      ok: false;
+      error: string;
+    };
+
 export type UiState = {
   panelOpen: boolean;
   daemon: { ok: boolean; authed: boolean; error?: string };
+  localRuntime: LocalRuntimeStatus | null;

+
+function isLocalRuntimeStatusPayload(
+  value: Record<string, unknown>,
+): value is LocalRuntimeStatusPayload {
+  return (
+    value.ok === true &&
+    isRecord(value.localOnly) &&
+    isRecord(value.runtime) &&

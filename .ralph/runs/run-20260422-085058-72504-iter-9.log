+  ok: boolean;
+  reachable: boolean;
+  runtimeType: LocalRuntimeKind | null;
+  runtimeLabel: string | null;
+  endpointHost: string | null;
+  timeoutMs: number;
+  models: {
+    count: number;
+    hints: string[];
+  };
+  server: {
+    status: number;
+    name?: string;
+    version?: string;
+  } | null;
+  error: {
+    code: string;
+    message: string;
+    status?: number;
+  } | null;
+};
+
+export type LocalRuntimeStatusPayload = {

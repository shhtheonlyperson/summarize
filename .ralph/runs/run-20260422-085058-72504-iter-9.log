+import type { LocalRuntimeStatus } from "../../lib/panel-contracts";
+
 const DAEMON_STATUS_TIMEOUT_MS = 5000;
+const DAEMON_LOCAL_RUNTIME_STATUS_TIMEOUT_MS = 4000;

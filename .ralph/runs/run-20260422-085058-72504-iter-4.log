+      id,
+      name: getStringField(item, "name"),
+      modifiedAt: getStringField(item, "modified_at"),
+      digest: getStringField(item, "digest"),
+      sizeBytes: getNumberField(item, "size"),
+      family: getStringField(details, "family"),

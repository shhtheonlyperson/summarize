+
+export type LocalRuntimeProbeFailure = {
+  ok: false;
+  reachable: false;
+  runtime?: LocalRuntimeDescriptor;
+  endpoint?: string;
+  timeoutMs: number;
+  error: LocalRuntimeProbeError;
+};
+
+export type LocalRuntimeProbeResult = LocalRuntimeProbeSuccess | LocalRuntimeProbeFailure;

+  endpoint?: string;
+  timeoutMs: number;
+  error: LocalRuntimeProbeError;
+};
+
+export type LocalRuntimeProbeResult = LocalRuntimeProbeSuccess | LocalRuntimeProbeFailure;
+
+export type LocalRuntimeProbeOptions = ParseLocalRuntimeDescriptorOptions & {

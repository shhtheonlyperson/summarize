+    expect(result).toMatchObject({
+      ok: false,
+      reachable: false,
+      timeoutMs: 1,
+      error: {
+        code: "timeout",
+        message: "Local runtime probe timed out after 1ms.",
+      },
+    });
+    const init = fetchMock.mock.calls[0]?.[1];
+    expect(init?.signal?.aborted).toBe(true);
+  });
+});


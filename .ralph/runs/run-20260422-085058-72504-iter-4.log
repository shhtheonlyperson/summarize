+  if (!Number.isFinite(timeoutMs)) return DEFAULT_LOCAL_RUNTIME_PROBE_TIMEOUT_MS;
+  return Math.max(0, timeoutMs ?? DEFAULT_LOCAL_RUNTIME_PROBE_TIMEOUT_MS);

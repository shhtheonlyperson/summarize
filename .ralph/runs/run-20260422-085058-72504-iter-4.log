+
+export async function probeOpenAiCompatibleLocalRuntime(
+  runtime: OpenAiCompatibleLocalRuntimeDescriptor | LlamaCppLocalRuntimeDescriptor,
+  options: LocalRuntimeProbeOptions = {},

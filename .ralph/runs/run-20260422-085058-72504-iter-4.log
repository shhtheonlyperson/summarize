+  const timeout = new Promise<FetchProbeJsonResult>((resolve) => {
+    timer = setTimeout(() => {
+      timedOut = true;
+      controller.abort();
+      resolve({
+        ok: false,
+        error: createTimeoutProbeError(timeoutMs),
+      });
+    }, timeoutMs);
+  });

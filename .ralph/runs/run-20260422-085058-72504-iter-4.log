+      try {
+        return {
+          ok: true,
+          response,
+          body: await response.json(),
+        };
+      } catch (error) {
+        if (timedOut || (error instanceof Error && error.name === "AbortError")) {
+          return {
+            ok: false,
+            error: createTimeoutProbeError(timeoutMs),
+          };
+        }

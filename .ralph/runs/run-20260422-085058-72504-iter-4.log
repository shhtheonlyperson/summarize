+  name?: string;
+  version?: string;
+};
+
+export type LocalRuntimeProbeSuccess = {
+  ok: true;
+  reachable: true;
+  runtime: LocalRuntimeDescriptor;
+  endpoint: string;
+  timeoutMs: number;
+  models: LocalRuntimeProbeModel[];
+  server: LocalRuntimeProbeServerMetadata;

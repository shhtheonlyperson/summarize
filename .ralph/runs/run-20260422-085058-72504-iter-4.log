+export const DEFAULT_LOCAL_RUNTIME_PROBE_TIMEOUT_MS = 3_000;
+
+export type LocalRuntimeProbeErrorCode =
+  | "invalid-runtime"
+  | "http-error"
+  | "malformed-response"
+  | "network-error"
+  | "timeout";
+
+export type LocalRuntimeProbeError = {
+  code: LocalRuntimeProbeErrorCode;
+  message: string;
+  status?: number;
